{
    "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/main/tauri.conf.json",
    "productName": "AI 讨论室",
    "version": "0.1.0",
    "identifier": "com.ai-chatroom.app",
    "build": {
        "frontendDist": "../out",
        "devUrl": "http://localhost:3000",
        "beforeDevCommand": "npm run dev",
        "beforeBuildCommand": "npm run build:static"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "AI 讨论室",
                "width": 1200,
                "height": 800,
                "minWidth": 800,
                "minHeight": 600,
                "center": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; connect-src 'self' http://localhost:8000 https://*.openai.com https://*.deepseek.com; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
        }
    },
    "plugins": {
        "shell": {
            "open": true
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "msi",
            "nsis"
        ],
        "icon": [
            "icons/icon.ico"
        ],
        "resources": [],
        "windows": {
            "certificateThumbprint": null,
            "digestAlgorithm": "sha256",
            "timestampUrl": ""
        }
    }
}